# ── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=billboard
DATABASE_URL="mysql://root:PASSWORD@localhost:3306/billboard"

# ── Auth / JWT ──────────────────────────────────────────────
SEC_KEY=
AUTH_KEY=

# ── AI: Gemini (primary provider) ───────────────────────────
KEY=                 # Google Gemini API key
API=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent

# ── AI: Claude (fallback provider) ──────────────────────────
# Leave ANTHROPIC_API_KEY empty to run Gemini-only (Claude auto-disables).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── AI: orchestration tuning (optional) ─────────────────────
AI_PROVIDER_PRIORITY=gemini,claude
AI_FALLBACK_ENABLED=true
AI_MAX_RETRIES=2
AI_TIMEOUT_MS=15000
AI_BREAKER_THRESHOLD=4
AI_BREAKER_COOLDOWN_MS=30000
